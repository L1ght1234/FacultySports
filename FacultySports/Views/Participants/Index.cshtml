@using FacultySports.MVC.Models.Participant
@model IEnumerable<ParticipantViewModel>

@{
    ViewData["Title"] = "Participants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <div class="text-muted">Manage all participants</div>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">Add Participant</a>
    </div>
</div>

<div class="row g-3">
    @foreach(var p in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@p.FirstName @p.LastName</h5>
                    <p class="card-text text-muted">
                        @if (!string.IsNullOrEmpty(p.Phone))
                        {
                            <span>@p.Phone</span>
                        }
                        else
                        {
                            <span>No phone</span>
                        }
                    </p>
                    <div class="mt-3 d-flex justify-content-end align-items-center gap-2">
                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
