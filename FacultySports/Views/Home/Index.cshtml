@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4">Welcome to Faculty Sports</h1>
            <p class="lead">Explore available sections and competitions</p>
            <div class="mt-4">
                <a asp-controller="Sections" asp-action="Index" class="btn btn-primary btn-lg me-3">View Sections</a>
                <a asp-controller="Competitions" asp-action="Index" class="btn btn-secondary btn-lg">View Competitions</a>
            </div>
        </div>
    </div>
</div>