@using FacultySports.MVC.Models.Competition
@model CompetitionViewModel

@{
    ViewData["Title"] = "Competition Details";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title">@Model.Title</h3>
                <hr />

                <dl class="row">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Model.Title</dd>
                    <dt class="col-sm-3">Date</dt>
                    <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-3">Start Time</dt>
                    <dd class="col-sm-9">@Model.StartTime.ToString("HH:mm")</dd>
                    <dt class="col-sm-3">Section</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.SectionName) ? "—" : Model.SectionName)</dd>
                    <dt class="col-sm-3">Location</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.LocationName) ? "—" : Model.LocationName)</dd>
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.StatusName) ? "—" : Model.StatusName)</dd>
                </dl>

                <div class="mt-4 d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="gap-2">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
