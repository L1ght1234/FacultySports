@using FacultySports.MVC.Models.Competition
@model IEnumerable<CompetitionViewModel>

@{
    ViewData["Title"] = "Competitions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <div class="text-muted">Manage all competitions</div>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">Add Competition</a>
    </div>
</div>

<div class="row g-3">
    @foreach(var c in Model)
    {
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0">@c.Title</h5>
                        @if (!string.IsNullOrEmpty(c.StatusName))
                        {
                            <span class="badge bg-info">@c.StatusName</span>
                        }
                    </div>
                    <p class="card-text text-muted mb-2">
                        📅 @c.Date.ToString("yyyy-MM-dd") at @c.StartTime.ToString("HH:mm")
                    </p>
                    <p class="card-text">
                        <strong>Section:</strong> @(c.SectionName ?? "—")<br />
                        <strong>Location:</strong> @(c.LocationName ?? "—")
                    </p>
                    <div class="mt-auto d-flex justify-content-end align-items-center gap-2">
                        <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
