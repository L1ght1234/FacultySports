@using FacultySports.MVC.Models.Schedule
@model IEnumerable<ScheduleViewModel>

@{
    ViewData["Title"] = "Schedules";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <div class="text-muted">Manage weekly schedules</div>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">Add Schedule</a>
    </div>
</div>

<div class="row g-3">
    @foreach(var s in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@GetDayName(s.DayOfWeek)</h5>
                    <p class="card-text">
                        🕒 @s.StartTime.ToString("HH:mm") - @s.EndTime.ToString("HH:mm")
                    </p>
                    <p class="card-text text-muted">Location: @(string.IsNullOrEmpty(s.LocationName) ? "—" : s.LocationName)</p>
                    <div class="mt-3 d-flex justify-content-end align-items-center gap-2">
                        <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@functions {
    private string GetDayName(int dayOfWeek)
    {
        return dayOfWeek switch
        {
            0 => "Sunday",
            1 => "Monday",
            2 => "Tuesday",
            3 => "Wednesday",
            4 => "Thursday",
            5 => "Friday",
            6 => "Saturday",
            _ => "Unknown"
        };
    }
}
