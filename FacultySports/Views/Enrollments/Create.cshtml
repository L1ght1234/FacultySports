@using FacultySports.MVC.Models.Enrollment
@model CreateEnrollmentViewModel

@{
    ViewData["Title"] = "Create Enrollment";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title mb-3">@ViewData["Title"]</h3>

                <form asp-action="Create" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Section</label>
                        @if (Model.SectionId > 0)
                        {
                            <input class="form-control" value="@ViewBag.SectionName" readonly />
                            <input type="hidden" asp-for="SectionId" />
                        }
                        else
                        {
                            <select asp-for="SectionId" class="form-select form-select-lg">
                                <option value="">-- Select Section --</option>
                                @if (ViewBag.Sections != null)
                                {
                                    foreach (var s in (IEnumerable<FacultySports.Contracts.Section.SectionDto>)ViewBag.Sections)
                                    {
                                        <option value="@s.Id">@s.Name</option>
                                    }
                                }
                            </select>
                        }
                        <span asp-validation-for="SectionId" class="text-danger"></span>
                    </div>

                    <hr />

                    <div class="mb-3">
                        <h5 class="mb-3">Participant Information</h5>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label">First Name</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label">Last Name</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Phone</label>
                            <input asp-for="Phone" class="form-control" placeholder="+1 (555) 123-4567" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Date" class="form-label">Enrollment Date</label>
                        <input asp-for="Date" class="form-control" type="date" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" onclick="history.back()" class="btn btn-outline-secondary">Cancel</button>
                        <button type="submit" class="btn btn-success">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
