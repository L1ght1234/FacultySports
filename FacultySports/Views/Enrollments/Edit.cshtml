@using FacultySports.MVC.Models.Enrollment
@model CreateEnrollmentViewModel

@{
    ViewData["Title"] = "Edit Enrollment";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title mb-3">@ViewData["Title"]</h3>

                <form asp-action="Edit" method="post">
                    <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />

                    <div class="mb-3">
                        <label asp-for="SectionId" class="form-label fw-bold">Section</label>
                        <select asp-for="SectionId" class="form-select">
                            <option value="">-- Select Section --</option>
                            @if (ViewBag.Sections != null)
                            {
                                foreach (var s in (IEnumerable<FacultySports.Contracts.Section.SectionDto>)ViewBag.Sections)
                                {
                                    if (s.Id == Model.SectionId)
                                    {
                                        <option value="@s.Id" selected>@s.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@s.Id">@s.Name</option>
                                    }
                                }
                            }
                        </select>
                        <span asp-validation-for="SectionId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParticipantId" class="form-label fw-bold">Participant</label>
                        <select asp-for="ParticipantId" class="form-select">
                            <option value="">-- Select Participant --</option>
                            @if (ViewBag.Participants != null)
                            {
                                foreach (var p in (IEnumerable<FacultySports.Contracts.Participant.ParticipantDto>)ViewBag.Participants)
                                {
                                    if (p.Id == Model.ParticipantId)
                                    {
                                        <option value="@p.Id" selected>@p.FirstName @p.LastName</option>
                                    }
                                    else
                                    {
                                        <option value="@p.Id">@p.FirstName @p.LastName</option>
                                    }
                                }
                            }
                        </select>
                        <span asp-validation-for="ParticipantId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Date" class="form-label">Enrollment Date</label>
                        <input asp-for="Date" class="form-control" type="date" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
