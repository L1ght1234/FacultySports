@using FacultySports.MVC.Models.Section
@model SectionViewModel

@{
    ViewData["Title"] = "Confirm deletion";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card border-danger shadow-sm">
            <div class="card-body">
                <h4 class="card-title">Delete section</h4>
                <p class="text-muted">Are you sure you want to delete section "<strong>@Model.Name</strong>"?</p>

                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
