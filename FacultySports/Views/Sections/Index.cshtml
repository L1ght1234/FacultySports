@using FacultySports.MVC.Models.Section
@* Указываем тип модели, которую ожидает эта страница *@
@model IEnumerable<SectionViewModel>

@{
    ViewData["Title"] = "Sports Sections";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <div class="text-muted">List of available sections</div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div>
            <a asp-action="Create" class="btn btn-primary">Add Section</a>
        </div>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@item.Name</h5>
                                <p class="card-text text-muted flex-grow-1">@(!string.IsNullOrEmpty(item.Description) ? item.Description : "— no description —")</p>
                                <div class="mt-3 d-flex justify-content-end align-items-center">
                                    <div>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">Details</a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                        }
                                        <a asp-controller="Enrollments" asp-action="Create" asp-route-sectionId="@item.Id" asp-route-returnUrl="@Url.Action("Index", "Sections")" class="btn btn-sm btn-outline-success me-1">Enroll</a>
                                    </div>
                                </div>
                            </div>
            </div>
        </div>
    }
</div>